<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Aurora launch theme: dark canvas so the cold-start window matches the
         Compose UI instead of flashing white. Parented to a no-action-bar
         Material3 base. -->
    <style name="Theme.SpeakToWrite" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/aurora_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="DropdownScrollView" parent="android:Widget.ScrollView">
        <item name="android:scrollbars">vertical</item>
        <item name="android:scrollbarThumbVertical">@drawable/scrollbar_thumb</item>
        <item name="android:scrollbarSize">4dp</item>
        <item name="android:fadeScrollbars">false</item>
    </style>
</resources>

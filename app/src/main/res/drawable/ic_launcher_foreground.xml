<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Ambient glow behind mic (matching url(#aura)) -->
    <path android:pathData="M 6,44 a 48,42 0 1,0 96,0 a 48,42 0 1,0 -96,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="45.36"
                android:gradientRadius="51.84"
                android:type="radial">
                <item
                    android:color="#4222C28E"
                    android:offset="0.0" />
                <item
                    android:color="#0022C28E"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Sound waves · LEFT -->
    <!-- inner arc -->
    <path
        android:pathData="M37,36 Q29,43 37,50"
        android:strokeColor="#22C28E"
        android:strokeWidth="2.3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:strokeAlpha="0.72" />
    <!-- outer arc -->
    <path
        android:pathData="M29,28 Q19,43 29,58"
        android:strokeColor="#22C28E"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:strokeAlpha="0.34" />

    <!-- Sound waves · RIGHT -->
    <!-- inner arc -->
    <path
        android:pathData="M71,36 Q79,43 71,50"
        android:strokeColor="#38EF7D"
        android:strokeWidth="2.3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:strokeAlpha="0.72" />
    <!-- outer arc -->
    <path
        android:pathData="M79,28 Q89,43 79,58"
        android:strokeColor="#38EF7D"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:strokeAlpha="0.34" />

    <!-- Microphone capsule (matching url(#mg)) -->
    <path android:pathData="M54,22h0a12,12 0,0 1,12 12v16a12,12 0,0 1,-12 12h0a12,12 0,0 1,-12 -12v-16a12,12 0,0 1,12 -12z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="22"
                android:endX="54"
                android:endY="62"
                android:type="linear">
                <item
                    android:color="#FF38EF7D"
                    android:offset="0.0" />
                <item
                    android:color="#FF22C28E"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Grille lines + specular highlight (clipped to capsule via clipPath) -->
    <group>
        <clip-path
            android:pathData="M54,22h0a12,12 0,0 1,12 12v16a12,12 0,0 1,-12 12h0a12,12 0,0 1,-12 -12v-16a12,12 0,0 1,12 -12z" />
        
        <path
            android:pathData="M42,35h24"
            android:strokeColor="#33000000"
            android:strokeWidth="1.1" />
        <path
            android:pathData="M42,40h24"
            android:strokeColor="#33000000"
            android:strokeWidth="1.1" />
        <path
            android:pathData="M42,45h24"
            android:strokeColor="#33000000"
            android:strokeWidth="1.1" />
        <path
            android:pathData="M42,50h24"
            android:strokeColor="#33000000"
            android:strokeWidth="1.1" />
        <path
            android:pathData="M42,55h24"
            android:strokeColor="#33000000"
            android:strokeWidth="1.1" />
            
        <!-- Glass specular highlight -->
        <path
            android:pathData="M48.5,30a3.5,6.5 0,1 0,7 0a3.5,6.5 0,1 0,-7 0"
            android:fillColor="#38FFFFFF" />
    </group>

    <!-- Capsule glass border (glassmorphism rim) -->
    <path
        android:pathData="M54,22h0a12,12 0,0 1,12 12v16a12,12 0,0 1,-12 12h0a12,12 0,0 1,-12 -12v-16a12,12 0,0 1,12 -12z"
        android:strokeColor="#42FFFFFF"
        android:strokeWidth="0.65"
        android:fillColor="#00000000" />

    <!-- Mic stand -->
    <!-- U-bracket: wraps below capsule -->
    <path
        android:pathData="M40,60 Q40,78 54,78 Q68,78 68,60"
        android:strokeColor="#2BD175"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
    <!-- Vertical stem -->
    <path
        android:pathData="M54,78 L54,87"
        android:strokeColor="#2BD175"
        android:strokeWidth="2.6"
        android:strokeLineCap="round" />
    <!-- Horizontal base -->
    <path
        android:pathData="M43,87 L65,87"
        android:strokeColor="#2BD175"
        android:strokeWidth="2.8"
        android:strokeLineCap="round" />

</vector>